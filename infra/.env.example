# ============================================================
# walkie-talkie — production env (lives at /opt/walkie-talkie/.env on the VM)
# Copy this file to ../.env then fill in every __from_secrets__ value.
# Generate any missing secrets with the commands in docs/truenas-deploy.md.
# chmod 600 .env after editing.
# ============================================================

# ----- Domain -----
DUCKDNS_DOMAIN=walkiehost.duckdns.org
ACME_EMAIL=easywaytomessage@gmail.com

# ----- Postgres -----
POSTGRES_DB=walkietalk
POSTGRES_USER=walkietalk
POSTGRES_PASSWORD=__from_secrets__
# Host path on the VM where Postgres data lives. Override if you mount a
# TrueNAS dataset somewhere else.
POSTGRES_DATA_PATH=/opt/walkie-talkie/postgres-data

# ----- Backend secrets (JWT) -----
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=__from_secrets__
JWT_REFRESH_SECRET=__from_secrets__

# ----- LiveKit -----
LIVEKIT_URL=wss://livekit.walkiehost.duckdns.org
# API_KEY pattern (must start with "API"):
#   node -e "console.log('API' + require('crypto').randomBytes(8).toString('hex'))"
LIVEKIT_API_KEY=__from_secrets__
# API_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LIVEKIT_API_SECRET=__from_secrets__

# ----- Optional: APNs push (Milestone 9) -----
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY=
