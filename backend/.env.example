# Local development env (Mac)
# For production, see /infra/.env.example
NODE_ENV=development
PORT=3000

# Points at the local Postgres started by `docker compose -f docker-compose.dev.yml up -d`
DATABASE_URL=postgres://walkietalk:walkietalk@localhost:5432/walkietalk

# Optional in Milestone 1 — required from Milestone 2 onwards.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# LiveKit (used from Milestone 3). For local dev you can point at the production
# LiveKit if you want, or run a local LiveKit container.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
